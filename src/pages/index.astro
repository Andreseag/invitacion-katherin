---

import Hero from '../components/Hero.astro';
import Layout from '../layouts/Layout.astro';
import fotoQuince from '../assets/image-1.jpeg';
import fotoQuince2 from '../assets/image-2.jpeg';
import WelcomeMessage from '../components/WelcomeMessage.astro';
import Countdown from '../components/Countdown.astro';
import Location from '../components/Location.astro';
import DressCode from '../components/DressCode.astro';
import RSVP from '../components/RSVP.astro';
import LluviaSobres from '../components/LluviaSobres.astro';
import Hashtag from '../components/Hashtag.astro';
import Gallery from '../components/Gallery.astro';

// Importas las fotos directamente
import foto1 from '../assets/image-1.jpeg';
import foto2 from '../assets/image-2.jpeg';
import foto3 from '../assets/image-3.jpeg';
import Footer from '../components/Footer.astro';
import InvitacionFamilia from '../components/InvitacionFamilia.astro';

const misFotos = [
  { url: foto1, alt: 'Katherin en el jardín' },
  { url: foto2, alt: 'Primer plano Katherin' },
  { url: foto3, alt: 'Vestido de 15 años' },
];

const urlSheet = 'https://script.google.com/macros/s/AKfycbwqUFR9ldCFlm_9um7l8pK-H-0_aBvpyMBK2FN8NCCa69C7F_ty2dq-DgVslWd5Pzak/exec'
const phoneNumber = "573115479052"

---

<Layout>
	<Hero name='Katherin Parales' date='13/06/2026' image={fotoQuince} />
  <WelcomeMessage />
  <InvitacionFamilia />
  <Countdown image={foto3} targetDate="2026-06-13T19:00:00" />
  <Location />
  <DressCode />
  <RSVP phoneNumber={phoneNumber} googleSheetUrl={urlSheet} />
  <!-- <LluviaSobres 
    nequi="300 123 4567" 
    cuentaBancaria="123-456789-01" 
    banco="Bancolombia"
  /> -->
  <Hashtag tag="#Mis15ConKatherin" />
  <Gallery images={misFotos} />
  <Footer />
</Layout>
