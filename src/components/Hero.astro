---
// src/components/Hero.astro
interface Props {
  name: string;
  date: string;
  image: any; 
}

const { name, date, image } = Astro.props;
const imageSrc = typeof image === 'string' ? image : image.src;
---

<section id="hero-section" class="relative h-[90vh] flex flex-col justify-end py-16 overflow-hidden bg-brand-light">
  <img 
    src={imageSrc}
    alt={`Foto de ${name}`}
    class="absolute inset-0 w-full h-full object-cover z-0"
  />

  <div class="absolute inset-0 bg-gradient-to-b from-brand/20 via-transparent to-brand/10 z-10"></div>
  
  <div class="relative z-20 text-center px-4">
    <h1 class="font-script text-brand-light text-[85px] md:text-9xl lg:text-[10rem] leading-tight drop-shadow-sm">
      Katherin
    </h1>
     <h1 class="font-script text-brand-light text-[85px] md:text-9xl lg:text-[10rem] leading-tight drop-shadow-sm">
      Parales
    </h1>
  </div>

  <div class="relative z-20 text-center px-4 mb-16"> <p class="uppercase tracking-[0.3em] text-brand-light font-sans mb-4">
      Mis Quince Años
    </p>
    
    <div class="flex items-center justify-center gap-4 mb-6">
      <div class="h-[1px] w-12 bg-brand/40"></div>
      <span class="font-serif text-brand-light text-2xl md:text-4xl tracking-widest uppercase">
        {date}
      </span>
      <div class="h-[1px] w-12 bg-brand/40"></div>
    </div>

    <p class="font-sans text-brand-light text-sm md:text-base tracking-[0.2em] uppercase">
      Arauquita, Arauca 
    </p>
  </div>

  <button 
    id="scroll-to-content" 
    class="absolute bottom-4 left-1/2 -translate-x-1/2 z-30 text-brand-light/80 hover:text-brand-light transition-colors duration-300 focus:outline-none cursor-pointer"
    aria-label="Ver más contenido"
  >
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      fill="none" 
      viewBox="0 0 24 24" 
      stroke-width="2" 
      stroke="currentColor" 
      class="w-8 h-8 animate-bounce"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
    </svg>
  </button>
</section>

<script>
  const scrollBtn = document.getElementById('scroll-to-content');
  
  if (scrollBtn) {
    scrollBtn.addEventListener('click', () => {
      const heroSection = document.getElementById('hero-section');
      // Busca el siguiente elemento hermano en el DOM para escrollear hacia él
      const nextSection = heroSection?.nextElementSibling;
      
      if (nextSection) {
        nextSection.scrollIntoView({ behavior: 'smooth' });
      }
    });
  }
</script>

<style>
  h1 {
    animation: fadeInDown 1.5s ease-out;
  }

  /* Animación suave para la parte de abajo también */
  div.relative:last-of-type {
    animation: fadeInUp 1.5s ease-out;
  }

  /* Animación de entrada para el botón */
  #scroll-to-content {
    animation: fadeInUp 2s ease-out;
  }

  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>